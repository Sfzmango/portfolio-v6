---
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';
import { selectedWork } from '../data/projects';
---

<section class="container-px pb-section">
  <SectionHeading eyebrow="Selected work" title="Additional projects." />

  <!-- Grid reflows 1 → 2 → 3 columns (sm/md/lg). -->
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      selectedWork.map((project, i) => (
        <div class="reveal min-w-0" style={`transition-delay:${i * 70}ms;`}>
          <ProjectCard project={project} />
        </div>
      ))
    }
  </div>
</section>
