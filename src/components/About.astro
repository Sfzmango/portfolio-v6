---
import { professionalSummary, identity, education } from '../data/skills';

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base}${p}`.replace(/([^:])\/\/+/g, '$1/');
const headshot = asset('/headshot.png');
const ega = asset('/usmc-ega.svg');
---

<section id="about" class="container-px py-section">
  <div class="grid gap-10 lg:grid-cols-[1.6fr,1fr] lg:gap-16">
    <div class="reveal">
      <p class="eyebrow mb-3">About</p>
      <h2 class="sec-rule text-fluid-2xl font-bold text-ink-strong">Engineering across payments and technology.</h2>

      <div class="mt-6 flex items-center gap-4">
        <!-- Small avatar (~96px) — native 250×250, never upscaled into a hero portrait. -->
        <img
          src={headshot}
          alt={`${identity.name} headshot`}
          width="96"
          height="96"
          loading="lazy"
          decoding="async"
          class="h-20 w-20 shrink-0 rounded-2xl border border-line object-cover shadow-glow sm:h-24 sm:w-24"
        />
        <div class="flex flex-col gap-2">
          <span class="font-mono text-fluid-sm text-ink">{identity.name}</span>
          <span class="veteran-badge">
            <!-- Eagle, Globe & Anchor — the detailed U.S. Marine Corps emblem, served
                 as a static asset (public/usmc-ega.svg) whose every shape is pre-baked
                 to the gilt service-ribbon tone (#c2a35f === var(--gilt)). Rendered as
                 an <img> (not a CSS mask): a flat mask collapses the line-art into a
                 solid blob, whereas the real shapes keep the dark page showing between
                 the gilt feathers/globe-grid/rope so the emblem stays legible. Sized
                 30px tall (native 400×440 → ~27.3px wide) — the smallest size where the
                 eagle, gridded globe and fouled anchor all still read. URL is base-aware
                 via the asset() helper for the /portfolio-v6 subpath. -->
            <img
              src={ega}
              width="27.3"
              height="30"
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
            />
            U.S. Marine Corps veteran
          </span>
        </div>
      </div>

      <p class="mt-6 text-fluid-base leading-relaxed text-ink-muted">{professionalSummary}</p>
      <p class="mt-4 text-fluid-base leading-relaxed text-ink-muted">
▎ A U.S. Marine Corps veteran based in San Bruno, CA, with a decade spent making things reliable — from optics and solar panels to payment pipelines. Careful review, measurable quality gates, and full ownership end-to-end.
      </p>
    </div>

    <aside class="reveal" style="transition-delay:120ms;">
      <div class="card p-6">
        <p class="eyebrow mb-4">Education & certs</p>
        <ul class="flex flex-col gap-4">
          {
            education.map((e) => (
              <li class="flex flex-col gap-0.5 border-l border-line pl-4">
                <span class="text-fluid-sm font-medium text-ink">{e.title}</span>
                <span class="font-mono text-fluid-xs text-ink-muted">
                  {e.org} · {e.year}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </div>
</section>

<style>
  /* Veteran badge — gilt service-ribbon tone. */
  .veteran-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    width: fit-content;
    /* Keep the pill compact around the taller EGA emblem: the line-box no longer
       drives the height, so the padding alone sets the vertical rhythm. */
    line-height: 1;
    font-family: var(--font-label);
    font-size: clamp(0.74rem, 0.7rem + 0.16vw, 0.84rem);
    letter-spacing: 0.08em;
    padding: 0.32em 0.7em;
    border-radius: 0.55rem;
    border: 1px solid rgba(194, 163, 95, 0.34);
    background: rgba(194, 163, 95, 0.1);
    color: var(--gilt-light);
  }
  .veteran-badge img {
    /* `block` drops the inline descender gap so the emblem centres cleanly
       against the text; `flex-shrink` guard keeps it crisp if the pill is tight.
       Explicit width/height attrs reserve the box up front (no layout shift on
       load); the gilt colour is pre-baked into the SVG, so no tint rule is needed. */
    display: block;
    flex-shrink: 0;
    height: 30px;
    width: auto;
  }
</style>
