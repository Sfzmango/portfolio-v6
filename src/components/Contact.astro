---
import ContactForm from './islands/ContactForm.tsx';
import { identity } from '../data/skills';

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base}${p}`.replace(/([^:])\/\/+/g, '$1/');
const resumeHref = asset('/maung-htike-resume.pdf');
---

<section id="contact" class="container-px py-section">
  <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
    <!-- Left: direct links -->
    <div class="reveal flex flex-col">
      <p class="eyebrow mb-3">Contact</p>
      <h2 class="sec-rule text-fluid-2xl font-bold text-ink-strong">Get in touch.</h2>
      <p class="mt-4 max-w-md text-fluid-base text-ink-muted">
        Open to engineering and tech roles. Use the form, or any
        of the direct links below.
      </p>

      <ul class="mt-8 flex flex-col gap-3">
        <li>
          <a
            href={`mailto:${identity.email}`}
            class="contact-link"
          >
            <span class="contact-icon" aria-hidden="true">✉</span>
            <span>{identity.email}</span>
          </a>
        </li>
        <li>
          <a href={identity.phoneHref} class="contact-link">
            <span class="contact-icon" aria-hidden="true">☎</span>
            <span>{identity.phone}</span>
          </a>
        </li>
        <li>
          <a href={identity.linkedin} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="contact-icon font-mono" aria-hidden="true">in</span>
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a href={identity.github} target="_blank" rel="noopener noreferrer" class="contact-link">
            <span class="contact-icon font-mono" aria-hidden="true">gh</span>
            <span>GitHub</span>
          </a>
        </li>
      </ul>

      <div class="mt-8">
        <a href={resumeHref} download class="btn btn-ghost">Download résumé</a>
      </div>
    </div>

    <!-- Right: EmailJS island (client:visible) -->
    <div class="reveal" style="transition-delay:100ms;">
      <ContactForm client:visible />
    </div>
  </div>
</section>

<style>
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.8em;
    font-size: clamp(0.95rem, 0.9rem + 0.3vw, 1.1rem);
    color: var(--ink);
    transition: color 0.2s ease;
  }
  .contact-link:hover {
    color: var(--accent-bright);
  }
  .contact-icon {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 0.6rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
    color: var(--accent);
    font-size: 0.95rem;
    flex-shrink: 0;
  }
</style>
