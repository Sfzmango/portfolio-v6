---
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';
import { featured } from '../data/projects';
---

<section id="work" class="container-px py-section">
  <SectionHeading
    eyebrow="Featured work"
    title="Two projects in focus."
    lede="A traditional Norse board game recreated for modern times, and a multi-agent AI system behind a production platform rebuild."
  />

  <div class="grid gap-6 lg:grid-cols-2">
    {
      featured.map((project, i) => (
        <div class="reveal min-w-0" style={`transition-delay:${i * 80}ms;`}>
          <ProjectCard project={project} featured />
        </div>
      ))
    }
  </div>
</section>
