---
import SectionHeading from './SectionHeading.astro';
import { experience } from '../data/experience';
import { identity } from '../data/skills';
---

<section id="experience" class="container-px py-section">
  <SectionHeading
    eyebrow="Experience"
    title="Nearly a decade of technical experience."
  />

  <div class="flex flex-col">
    {
      experience.map((job, i) => (
        <div
          class="reveal grid gap-4 border-t border-line py-7 sm:grid-cols-[minmax(0,11rem),1fr] sm:gap-8 sm:py-9"
          style={`transition-delay:${Math.min(i * 60, 240)}ms;`}
        >
          {/* Mono date-range rail */}
          <div class="flex flex-col gap-1">
            <span class="font-mono text-fluid-xs uppercase tracking-wider text-accent">
              {job.dateRange}
            </span>
            {job.location && (
              <span class="font-mono text-fluid-xs text-ink-muted">{job.location}</span>
            )}
            {job.veteran && (
              <span class="mt-1 w-fit rounded-md border border-accent/30 bg-accent/5 px-2 py-0.5 font-mono text-[0.62rem] uppercase tracking-wider text-accent-bright">
                veteran
              </span>
            )}
          </div>

          <div class="flex flex-col gap-3">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <h3 class="text-fluid-lg font-semibold text-ink">{job.role}</h3>
              <span class="text-ink-muted">·</span>
              <span class="text-fluid-base font-medium text-accent">{job.company}</span>
              {job.note && (
                <span class="font-mono text-fluid-xs text-ink-muted">({job.note})</span>
              )}
            </div>
            <ul class="flex flex-col gap-3">
              {job.bullets.map((b) => (
                <li class="flex items-start gap-2.5 text-fluid-sm leading-relaxed text-ink-muted">
                  <span class="mt-[0.15em] shrink-0 select-none text-accent" aria-hidden="true">▸</span>
                  {/* pl + equal negative text-indent: first line stays flush, every
                      wrapped line shifts right by the indent for a clearer block. */}
                  <span class="pl-5 [text-indent:-1.25rem]">{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
    <div class="border-t border-line"></div>
    
    <div class="mt-8 flex justify-center">
      <a
        href={identity.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary"
      >
        See the whole journey on LinkedIn ↗
      </a>
    </div>
  </div>
</section>
