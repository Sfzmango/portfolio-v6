---
import SectionHeading from './SectionHeading.astro';
import TechChip from './TechChip.astro';
import { skillGroups } from '../data/skills';
---

<section id="skills" class="container-px py-section">
  <SectionHeading eyebrow="Skills" title="The toolkit." />

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      skillGroups.map((group, i) => (
        <div class="reveal card p-6" style={`transition-delay:${Math.min(i * 60, 240)}ms;`}>
          <h3 class="mb-4 font-mono text-fluid-sm uppercase tracking-wider text-accent">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {group.skills.map((s) => (
              <TechChip label={s} />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
