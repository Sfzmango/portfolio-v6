# Portfolio v6 — environment variables (example)
#
# Copy to `.env` and fill in. In Astro, only vars prefixed PUBLIC_ are exposed to
# client-side code. EmailJS keys are PUBLISHABLE (client-side by design), so PUBLIC_
# is correct here — they are NOT secrets. Lock down abuse via the EmailJS dashboard
# (allowed origins + rate limits), not by hiding these.
#
# `.env` is gitignored; `.env.example` is committed as the contract.

PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
